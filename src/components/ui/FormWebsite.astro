---
interface Props {
    formId?: string;
}

const { formId = "form-website" } = Astro.props;

const projectTypes = [
    "Strona firmowa",
    "Sklep internetowy",
    "Landing page",
    "Redesign istniejącej strony",
    "Nie wiem jeszcze",
];

const budgets = [
    "do 5 000 zł",
    "5 000 – 10 000 zł",
    "10 000 – 20 000 zł",
    "powyżej 20 000 zł",
    "Nie wiem jeszcze",
];

const timelines = [
    "Jak najszybciej (do 4 tygodni)",
    "1–2 miesiące",
    "2–4 miesiące",
    "Bez konkretnego terminu",
];
---

<form id={formId} class="space-y-6">
    <input type="hidden" name="access_key" value="5d5064fd-bd60-4fa1-9a68-0fff3e929977" />
    <input type="hidden" name="subject" value="Zapytanie: Strony które zarabiają" />
    <div>
        <label for="w-name" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Imię i Nazwisko
        </label>
        <input
            type="text"
            name="name"
            id="w-name"
            autocomplete="name"
            required
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="Jan Kowalski"
        />
    </div>
    <div>
        <label for="w-email" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Email firmowy
        </label>
        <input
            type="email"
            name="email"
            id="w-email"
            autocomplete="email"
            required
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="jan@firma.pl"
        />
    </div>
    <div>
        <label for="w-project-type" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Rodzaj projektu
        </label>
        <select
            name="project_type"
            id="w-project-type"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz rodzaj projektu</option>
            {projectTypes.map((t) => (
                <option value={t} class="bg-background text-foreground">{t}</option>
            ))}
        </select>
    </div>
    <div>
        <label for="w-url" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Adres obecnej strony <span class="normal-case">(jeśli masz)</span>
        </label>
        <input
            type="url"
            name="url"
            id="w-url"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="https://twojafirma.pl"
        />
    </div>
    <div>
        <label for="w-budget" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Budżet na projekt
        </label>
        <select
            name="budget"
            id="w-budget"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz przedział</option>
            {budgets.map((b) => (
                <option value={b} class="bg-background text-foreground">{b}</option>
            ))}
        </select>
    </div>
    <div>
        <label for="w-timeline" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Preferowany termin realizacji
        </label>
        <select
            name="timeline"
            id="w-timeline"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz termin</option>
            {timelines.map((t) => (
                <option value={t} class="bg-background text-foreground">{t}</option>
            ))}
        </select>
    </div>
    <div>
        <label for="w-message" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Opisz projekt
        </label>
        <textarea
            name="message"
            id="w-message"
            rows="4"
            class="w-full bg-transparent border border-current/20 focus:border-current outline-none p-3 transition-colors placeholder:text-current/20 text-current resize-none"
            placeholder="Czym zajmuje się Twoja firma, co ma robić strona, kto jest odbiorcą, co Ci się podoba w stronach konkurencji..."
        ></textarea>
    </div>
    <div>
        <button
            type="submit"
            class="bg-background text-foreground px-8 py-3 rounded-full font-medium hover:bg-background/80 transition w-full md:w-auto disabled:opacity-50 disabled:cursor-not-allowed"
        >
            <span class="submit-text">Wyślij zapytanie</span>
            <span class="loading-text hidden">Wysyłanie...</span>
        </button>
    </div>
    <div class="result-message hidden mt-4 p-4 rounded-lg text-sm"></div>
</form>

<script define:vars={{ formId }}>
    const form = document.getElementById(formId);
    const button = form.querySelector('button[type="submit"]');
    const submitText = button.querySelector('.submit-text');
    const loadingText = button.querySelector('.loading-text');
    const resultMessage = form.querySelector('.result-message');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Disable button and show loading
        button.disabled = true;
        submitText.classList.add('hidden');
        loadingText.classList.remove('hidden');
        resultMessage.classList.add('hidden');

        const formData = new FormData(form);

        try {
            const response = await fetch("https://api.web3forms.com/submit", {
                method: "POST",
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                // Show success message
                resultMessage.textContent = "✓ Dziękujemy! Twoje zapytanie zostało wysłane. Skontaktujemy się wkrótce.";
                resultMessage.className = "result-message mt-4 p-4 rounded-lg text-sm bg-green-500/10 text-green-500 border border-green-500/20";
                resultMessage.classList.remove('hidden');

                // Reset form
                form.reset();
            } else {
                throw new Error(data.message || "Wystąpił błąd");
            }
        } catch (error) {
            // Show error message
            resultMessage.textContent = "✗ Wystąpił błąd podczas wysyłania formularza. Spróbuj ponownie lub skontaktuj się z nami telefonicznie.";
            resultMessage.className = "result-message mt-4 p-4 rounded-lg text-sm bg-red-500/10 text-red-500 border border-red-500/20";
            resultMessage.classList.remove('hidden');
        } finally {
            // Re-enable button and restore text
            button.disabled = false;
            submitText.classList.remove('hidden');
            loadingText.classList.add('hidden');
        }
    });
</script>
