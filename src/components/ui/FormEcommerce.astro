---
interface Props {
    formId?: string;
}

const { formId = "form-ecommerce" } = Astro.props;

const platforms = [
    "Shopify",
    "WooCommerce",
    "Magento / Adobe Commerce",
    "PrestaShop",
    "Shoper",
    "IdoSell",
    "BaseLinker + headless",
    "Inne / Custom",
];

const budgets = [
    "do 2 000 zł / mies.",
    "2 000 – 5 000 zł / mies.",
    "5 000 – 10 000 zł / mies.",
    "powyżej 10 000 zł / mies.",
    "Nie wiem jeszcze",
];
---

<form id={formId} class="space-y-6">
    <input type="hidden" name="access_key" value="5d5064fd-bd60-4fa1-9a68-0fff3e929977" />
    <input type="hidden" name="subject" value="Zapytanie: SEO E-commerce" />
    <div>
        <label for="ec-name" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Imię i Nazwisko
        </label>
        <input
            type="text"
            name="name"
            id="ec-name"
            autocomplete="name"
            required
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="Jan Kowalski"
        />
    </div>
    <div>
        <label for="ec-email" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Email firmowy
        </label>
        <input
            type="email"
            name="email"
            id="ec-email"
            autocomplete="email"
            required
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="jan@sklep.pl"
        />
    </div>
    <div>
        <label for="ec-url" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Adres sklepu
        </label>
        <input
            type="url"
            name="url"
            id="ec-url"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="https://twojsklep.pl"
        />
    </div>
    <div>
        <label for="ec-platform" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Platforma e-commerce
        </label>
        <select
            name="platform"
            id="ec-platform"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz platformę</option>
            {platforms.map((p) => (
                <option value={p} class="bg-background text-foreground">{p}</option>
            ))}
        </select>
    </div>
    <div>
        <label for="ec-budget" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Miesięczny budżet na SEO
        </label>
        <select
            name="budget"
            id="ec-budget"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz przedział</option>
            {budgets.map((b) => (
                <option value={b} class="bg-background text-foreground">{b}</option>
            ))}
        </select>
    </div>
    <div>
        <label for="ec-message" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Informacje dodatkowe
        </label>
        <textarea
            name="message"
            id="ec-message"
            rows="4"
            class="w-full bg-transparent border border-current/20 focus:border-current outline-none p-3 transition-colors placeholder:text-current/20 text-current resize-none"
            placeholder="Opisz swój sklep, aktualne wyzwania SEO, liczbę produktów lub kategorie, o których chcesz porozmawiać..."
        ></textarea>
    </div>
    <div>
        <button
            type="submit"
            class="bg-background text-foreground px-8 py-3 rounded-full font-medium hover:bg-background/80 transition w-full md:w-auto disabled:opacity-50 disabled:cursor-not-allowed"
        >
            <span class="submit-text">Zamów bezpłatną analizę</span>
            <span class="loading-text hidden">Wysyłanie...</span>
        </button>
    </div>
    <div class="result-message hidden mt-4 p-4 rounded-lg text-sm"></div>
</form>

<script define:vars={{ formId }}>
    const form = document.getElementById(formId);
    const button = form.querySelector('button[type="submit"]');
    const submitText = button.querySelector('.submit-text');
    const loadingText = button.querySelector('.loading-text');
    const resultMessage = form.querySelector('.result-message');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Disable button and show loading
        button.disabled = true;
        submitText.classList.add('hidden');
        loadingText.classList.remove('hidden');
        resultMessage.classList.add('hidden');

        const formData = new FormData(form);

        try {
            const response = await fetch("https://api.web3forms.com/submit", {
                method: "POST",
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                // Show success message
                resultMessage.textContent = "✓ Dziękujemy! Twoje zapytanie zostało wysłane. Skontaktujemy się wkrótce z bezpłatną analizą.";
                resultMessage.className = "result-message mt-4 p-4 rounded-lg text-sm bg-green-500/10 text-green-500 border border-green-500/20";
                resultMessage.classList.remove('hidden');

                // Reset form
                form.reset();
            } else {
                throw new Error(data.message || "Wystąpił błąd");
            }
        } catch (error) {
            // Show error message
            resultMessage.textContent = "✗ Wystąpił błąd podczas wysyłania formularza. Spróbuj ponownie lub skontaktuj się z nami telefonicznie.";
            resultMessage.className = "result-message mt-4 p-4 rounded-lg text-sm bg-red-500/10 text-red-500 border border-red-500/20";
            resultMessage.classList.remove('hidden');
        } finally {
            // Re-enable button and restore text
            button.disabled = false;
            submitText.classList.remove('hidden');
            loadingText.classList.add('hidden');
        }
    });
</script>
