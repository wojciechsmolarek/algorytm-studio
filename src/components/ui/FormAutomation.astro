---
interface Props {
    formId?: string;
}

const { formId = "form-automation" } = Astro.props;

const companySize = [
    "1–10 osób",
    "11–50 osób",
    "51–200 osób",
    "powyżej 200 osób",
];

const budgets = [
    "do 2 000 zł (jednorazowo)",
    "2 000 – 5 000 zł (jednorazowo)",
    "5 000 – 15 000 zł (jednorazowo)",
    "Interesuje mnie abonament miesięczny",
    "Nie wiem jeszcze",
];
---

<form id={formId} class="space-y-6">
    <input type="hidden" name="access_key" value="5d5064fd-bd60-4fa1-9a68-0fff3e929977" />
    <input type="hidden" name="subject" value="Zapytanie: Automatyzacje AI" />
    <div>
        <label for="aut-name" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Imię i Nazwisko
        </label>
        <input
            type="text"
            name="name"
            id="aut-name"
            autocomplete="name"
            required
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="Jan Kowalski"
        />
    </div>
    <div>
        <label for="aut-email" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Email firmowy
        </label>
        <input
            type="email"
            name="email"
            id="aut-email"
            autocomplete="email"
            required
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="jan@firma.pl"
        />
    </div>
    <div>
        <label for="aut-url" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Adres strony firmowej
        </label>
        <input
            type="url"
            name="url"
            id="aut-url"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors placeholder:text-current/20 text-current"
            placeholder="https://twojafirma.pl"
        />
    </div>
    <div>
        <label for="aut-process" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Jaki proces chcesz zautomatyzować?
        </label>
        <textarea
            name="process"
            id="aut-process"
            rows="4"
            required
            class="w-full bg-transparent border border-current/20 focus:border-current outline-none p-3 transition-colors placeholder:text-current/20 text-current resize-none"
            placeholder="Opisz co teraz dzieje się ręcznie — np. &quot;co tydzień ręcznie przepisujemy dane z formularzy do CRM i wysyłamy powiadomienia do handlowców&quot;"
        ></textarea>
    </div>
    <div>
        <label for="aut-size" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Wielkość firmy
        </label>
        <select
            name="company_size"
            id="aut-size"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz przedział</option>
            {companySize.map((s) => (
                <option value={s} class="bg-background text-foreground">{s}</option>
            ))}
        </select>
    </div>
    <div>
        <label for="aut-budget" class="block text-xs uppercase tracking-widest text-current/50 mb-2">
            Budżet na projekt
        </label>
        <select
            name="budget"
            id="aut-budget"
            class="w-full bg-transparent border-b border-current/20 focus:border-current outline-none py-2 transition-colors text-current appearance-none cursor-pointer"
        >
            <option value="" disabled selected class="bg-background text-foreground">Wybierz przedział</option>
            {budgets.map((b) => (
                <option value={b} class="bg-background text-foreground">{b}</option>
            ))}
        </select>
    </div>
    <div>
        <button
            type="submit"
            class="bg-background text-foreground px-8 py-3 rounded-full font-medium hover:bg-background/80 transition w-full md:w-auto disabled:opacity-50 disabled:cursor-not-allowed"
        >
            <span class="submit-text">Umów bezpłatną konsultację</span>
            <span class="loading-text hidden">Wysyłanie...</span>
        </button>
    </div>
    <div class="result-message hidden mt-4 p-4 rounded-lg text-sm"></div>
</form>

<script define:vars={{ formId }}>
    const form = document.getElementById(formId);
    const button = form.querySelector('button[type="submit"]');
    const submitText = button.querySelector('.submit-text');
    const loadingText = button.querySelector('.loading-text');
    const resultMessage = form.querySelector('.result-message');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Disable button and show loading
        button.disabled = true;
        submitText.classList.add('hidden');
        loadingText.classList.remove('hidden');
        resultMessage.classList.add('hidden');

        const formData = new FormData(form);

        try {
            const response = await fetch("https://api.web3forms.com/submit", {
                method: "POST",
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                // Show success message
                resultMessage.textContent = "✓ Dziękujemy! Twoje zapytanie zostało wysłane. Skontaktujemy się wkrótce.";
                resultMessage.className = "result-message mt-4 p-4 rounded-lg text-sm bg-green-500/10 text-green-500 border border-green-500/20";
                resultMessage.classList.remove('hidden');

                // Reset form
                form.reset();
            } else {
                throw new Error(data.message || "Wystąpił błąd");
            }
        } catch (error) {
            // Show error message
            resultMessage.textContent = "✗ Wystąpił błąd podczas wysyłania formularza. Spróbuj ponownie lub skontaktuj się z nami telefonicznie.";
            resultMessage.className = "result-message mt-4 p-4 rounded-lg text-sm bg-red-500/10 text-red-500 border border-red-500/20";
            resultMessage.classList.remove('hidden');
        } finally {
            // Re-enable button and restore text
            button.disabled = false;
            submitText.classList.remove('hidden');
            loadingText.classList.add('hidden');
        }
    });
</script>
