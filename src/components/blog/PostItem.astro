---
import Tags from "../ui/Tags.astro";
import { type CollectionEntry } from "astro:content";
import type { BlogPost } from "../../lib/wordpress";

type PostData = {
    title: string;
    description: string;
    pubDate: Date | string;
    author: string;
    authorSlug?: string;
    image?: string;
    tags?: string[];
    category?: string;
    categorySlug?: string;
};

export interface Props {
    post: CollectionEntry<"blog"> | BlogPost;
}

const { post } = Astro.props;

const data: PostData = "data" in post ? post.data : post;
const id = "id" in post ? post.id : (post as CollectionEntry<"blog">).id;
const authorSlug = data.authorSlug;
const pubDate = typeof data.pubDate === "string" ? new Date(data.pubDate) : data.pubDate;
---

<article
    class="group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
>
    <div class="relative h-48 w-full overflow-hidden">
        {
            data.image && (
                <img
                    src={data.image}
                    alt={data.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
            )
        }
    </div>
    <div class="flex flex-1 flex-col p-6">
        <div class="flex-1">
            <p class="text-sm font-medium text-primary">
                {authorSlug ? (
                    <a href={`/blog/autor/${authorSlug}`} class="hover:underline">{data.author}</a>
                ) : (
                    data.author
                )}
            </p>
            <a href={`/blog/${id}`} class="mt-2 block">
                <p
                    class="text-xl font-semibold text-foreground group-hover:underline"
                >
                    {data.title}
                </p>
                <p class="mt-3 text-base text-muted-foreground line-clamp-3">
                    {data.description}
                </p>
            </a>
        </div>
        <div class="mt-6 flex items-center">
            <div class="shrink-0">
                <span class="sr-only">
                    {data.author}
                </span>
            </div>
            <div class="">
                <div class="flex space-x-1 text-sm text-muted-foreground">
                    <time datetime={pubDate.toISOString()}>
                        {
                            pubDate.toLocaleDateString("pl-PL", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                                timeZone: "UTC",
                            })
                        }
                    </time>
                </div>
            </div>
        </div>

        {
            data.tags && data.tags.length > 0 && (
                <div class="mt-4">
                    <Tags tags={data.tags} />
                </div>
            )
        }
    </div>
</article>
