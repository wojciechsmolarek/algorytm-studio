---
import { siteConfig } from "../../config/site";
import Form from "../ui/Form.astro";
---

<footer
    class="bg-primary text-white pt-24 pb-12 px-6 md:px-12 lg:px-24"
    id="contact"
>
    <div class="max-w-6xl mx-auto">
        <!-- Contact Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-20">
            <div class="reveal-on-scroll">
                <span class="inline-block bg-white/10 text-white px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Kontakt</span>
                <h2
                    class="font-serif text-3xl md:text-5xl leading-tight mb-6"
                >
                    Porozmawiajmy o Twoim projekcie
                </h2>
                <p class="text-white/70 text-lg max-w-md leading-relaxed">
                    Masz pomysł na stronę, sklep lub potrzebujesz wsparcia SEO? Napisz do nas — odpisujemy osobiście.
                </p>
                <a
                    class="mt-8 inline-block text-xl font-medium border-b-2 border-white/30 pb-1 hover:border-white transition-colors"
                    href={`mailto:${siteConfig.email}`}
                >
                    {siteConfig.email}
                </a>
                <p class="mt-4 text-white/70">{siteConfig.tel}</p>
            </div>
            <div
                class="bg-white/10 p-8 md:p-10 rounded-3xl border border-white/10 reveal-on-scroll"
            >
                <Form formId="contact-form-footer" />
            </div>
        </div>

        <!-- Footer Bottom -->
        <div
            class="border-t border-white/10 pt-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-8 text-sm text-white/60"
        >
            <div>
                <p class="font-serif text-lg text-white mb-1">{siteConfig.name}</p>
                <p>Bydgoszcz, Polska</p>
            </div>
            <div class="text-xs">
                &copy; {new Date().getFullYear()}
                {siteConfig.name}. All rights reserved.
                <a
                    class="underline ml-2 hover:text-white transition"
                    href="/polityka-prywatnosci">Polityka prywatności</a
                >
            </div>
        </div>
    </div>
</footer>
