---
import { siteConfig } from "../../config/site";
---

<nav
    class="fixed top-0 w-full z-50 px-6 py-4 flex justify-between items-center text-foreground bg-background/80 backdrop-blur-md border-b border-border"
>
    <!-- Logo -->
    <div class="z-50">
        <a
            href="/"
            aria-label="Studio Algorytm Home"
            class="pointer-events-auto flex items-center gap-3"
        >
            <img src="/images/logo/logo-mark.svg" alt="" class="w-8 h-8" />
            <span class="font-serif text-2xl font-medium text-foreground">Studio Algorytm</span>
        </a>
    </div>

    <!-- Desktop Menu -->
    <div
        class="hidden md:flex gap-8 text-sm font-medium pointer-events-auto items-center"
    >
        {
            siteConfig.navLinks.map((link) =>
                link.children ? (
                    <div class="relative group">
                        {link.href ? (
                            <a
                                href={link.href}
                                class="text-foreground/80 hover:text-primary transition-colors flex items-center gap-1 peer"
                            >
                                {link.text}
                                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </a>
                        ) : (
                            <span class="text-foreground/80 hover:text-primary transition-colors flex items-center gap-1 peer cursor-default">
                                {link.text}
                                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        )}
                        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
                            <div class="bg-card border border-border rounded-2xl shadow-xl py-3 min-w-[260px]">
                                {link.children.map((child) => (
                                    <a
                                        href={child.href}
                                        class="block px-5 py-2.5 text-sm text-foreground/80 hover:text-primary hover:bg-muted transition-colors rounded-xl mx-1"
                                    >
                                        {child.text}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                ) : (
                    <a
                        href={link.href}
                        class="text-foreground/80 hover:text-primary transition-colors"
                    >
                        {link.text}
                    </a>
                )
            )
        }
        <a
            href="/kontakt"
            class="bg-primary text-white px-5 py-2.5 rounded-full text-sm font-medium hover:scale-105 transition-transform"
        >
            Darmowa wycena
        </a>
    </div>

    <!-- Hamburger / Mobile Menu Button -->
    <div class="md:hidden flex items-center z-50">
        <button
            id="mobile-menu-button"
            class="pointer-events-auto group p-2 -mr-2 focus:outline-none"
            type="button"
            aria-controls="mobile-menu"
            aria-expanded="false"
            aria-label="Toggle menu"
        >
            <div class="w-6 h-5 flex flex-col justify-between items-end">
                <span
                    class="w-full h-0.5 bg-foreground transition-all group-[[aria-expanded='true']]:rotate-45 group-[[aria-expanded='true']]:translate-y-[9px]"
                ></span>
                <span
                    class="w-4/5 h-0.5 bg-foreground transition-all group-[[aria-expanded='true']]:opacity-0"
                ></span>
                <span
                    class="w-full h-0.5 bg-foreground transition-all group-[[aria-expanded='true']]:-rotate-45 group-[[aria-expanded='true']]:-translate-y-[9px]"
                ></span>
            </div>
        </button>
    </div>
</nav>

<!-- Mobile Full-Screen Menu -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-[45] bg-background text-foreground hidden flex-col items-center justify-center translate-x-full transition-transform duration-300"
>
    <div class="flex flex-col items-center gap-6 max-h-[80vh] overflow-y-auto px-6">
        {
            siteConfig.navLinks.map((link) =>
                link.children ? (
                    <div class="flex flex-col items-center gap-3">
                        <span class="text-3xl font-serif text-primary">
                            {link.text}
                        </span>
                        <div class="flex flex-col items-center gap-2">
                            {link.children.map((child) => (
                                <a
                                    href={child.href}
                                    class="text-lg text-muted-foreground hover:text-primary transition mobile-menu-link"
                                >
                                    {child.text}
                                </a>
                            ))}
                        </div>
                    </div>
                ) : (
                    <a
                        href={link.href}
                        class="text-3xl font-serif hover:text-primary transition mobile-menu-link"
                    >
                        {link.text}
                    </a>
                )
            )
        }
        <a
            href="/kontakt"
            class="mt-4 bg-primary text-white px-8 py-3 rounded-full text-lg font-medium mobile-menu-link"
        >
            Kontakt
        </a>
    </div>
</div>

<script>
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    function toggleMenu() {
        const isExpanded = button?.getAttribute("aria-expanded") === "true";
        if (isExpanded) {
            closeMenu();
        } else {
            openMenu();
        }
    }

    function openMenu() {
        menu?.classList.remove("hidden");
        requestAnimationFrame(() => {
            menu?.classList.remove("translate-x-full");
            menu?.classList.add("translate-x-0");
            menu?.classList.add("flex");
        });
        button?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
    }

    function closeMenu() {
        menu?.classList.add("translate-x-full");
        menu?.classList.remove("translate-x-0");

        button?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";

        setTimeout(() => {
            if (button?.getAttribute("aria-expanded") === "false") {
                menu?.classList.add("hidden");
                menu?.classList.remove("flex");
            }
        }, 300);
    }

    button?.addEventListener("click", toggleMenu);

    document.querySelectorAll(".mobile-menu-link").forEach((link) => {
        link.addEventListener("click", closeMenu);
    });
</script>
