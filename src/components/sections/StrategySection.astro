---
interface StrategyColumn {
	title: string;
	description: string;
}

interface Props {
	headline: string;
	columns: StrategyColumn[];
}

const { headline, columns } = Astro.props;
---

<section class="py-24 px-6 md:px-12 lg:px-24 bg-muted">
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-16 reveal-on-scroll">
			<h2 class="font-serif text-4xl md:text-5xl mb-5 text-balance">{headline}</h2>
			<p class="text-muted-foreground text-lg max-w-2xl mx-auto leading-relaxed">
				Każdy projekt traktujemy jak własny. Nie sprzedajemy szablonów — budujemy rozwiązania dopasowane do Twojego biznesu.
			</p>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{columns.map((col, i) => (
				<div class="reveal-on-scroll bg-card rounded-3xl p-8 border border-border">
					<div class="w-10 h-10 rounded-full bg-accent/20 text-accent-foreground flex items-center justify-center font-serif text-lg mb-5">
						{String(i + 1).padStart(2, "0")}
					</div>
					<h3 class="text-xl font-medium text-foreground mb-4">{col.title}</h3>
					<p class="text-muted-foreground leading-relaxed" set:html={col.description} />
				</div>
			))}
		</div>
	</div>
</section>
