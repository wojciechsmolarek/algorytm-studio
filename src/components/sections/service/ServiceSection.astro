---
interface Props {
	tagline: string;
	title: string;
	highlight?: string;
	description?: string;
	centered?: boolean;
	muted?: boolean;
}

const { tagline, title, highlight, description, centered = false, muted = false } = Astro.props;
---

<section class={`py-20 px-6 md:px-12 lg:px-24 ${muted ? 'bg-muted' : ''}`}>
	<div class="max-w-6xl mx-auto">
		<div class={`mb-14 reveal-on-scroll ${centered ? 'text-center' : ''}`}>
			<span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">{tagline}</span>
			<h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">
				{title}
				{highlight && <span class="text-primary">{highlight}</span>}
			</h2>
			{description && <p class="text-muted-foreground text-lg max-w-2xl leading-relaxed">{description}</p>}
		</div>
		<slot />
	</div>
</section>
