---
interface Props {
	tagline: string;
	headline: string;
	description: string;
}

const { tagline, headline, description } = Astro.props;
---

<section class="py-24 px-6 md:px-12 lg:px-24 relative overflow-hidden">
	<div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-accent/20 to-transparent pointer-events-none rounded-l-[6rem]"></div>
	<div class="max-w-5xl mx-auto relative z-10">
		<span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6 reveal-on-scroll">{tagline}</span>
		<h2 class="font-serif text-4xl md:text-5xl lg:text-6xl leading-tight reveal-on-scroll text-pretty" set:html={headline} />
		<div class="mt-10 flex items-start gap-4 reveal-on-scroll">
			<div class="w-16 h-1 bg-accent rounded-full shrink-0 mt-3"></div>
			<p class="text-lg max-w-xl text-muted-foreground leading-relaxed">{description}</p>
		</div>
	</div>
</section>
