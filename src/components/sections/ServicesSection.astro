---
interface ServiceItem {
	num: string;
	title: string;
	description: string;
	tags: string[];
	href: string;
}

interface Props {
	services: ServiceItem[];
}

const { services } = Astro.props;
---

<section class="py-32 px-6 md:px-12 lg:px-24" id="services">
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-20 reveal-on-scroll">
			<span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Co robimy</span>
			<h2 class="font-serif text-4xl md:text-5xl mb-5">W czym możemy Ci pomóc?</h2>
			<p class="text-muted-foreground text-lg max-w-2xl mx-auto leading-relaxed">
				Osiem usług, które realnie wpływają na wzrost Twojego biznesu online.
			</p>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
			{services.map((service, i) => (
				<article class="group bg-card rounded-3xl p-10 border border-border reveal-on-scroll hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
					<div class="w-12 h-12 rounded-2xl bg-muted flex items-center justify-center mb-8 text-primary font-serif text-2xl">
						{service.num}
					</div>
					<h3 class="text-2xl font-serif mb-4">{service.title}</h3>
					<p class="text-muted-foreground leading-relaxed mb-8 flex-grow">{service.description}</p>
					<ul class="text-sm text-muted-foreground flex flex-col gap-2 mb-8">
						{service.tags.map((tag) => (
							<li class="flex items-center gap-2">
								<span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
								{tag}
							</li>
						))}
					</ul>
					<a class="inline-flex items-center gap-2 text-primary font-medium group/link" href={service.href}>
						Zobacz więcej
						<span class="group-hover/link:translate-x-1 transition-transform">→</span>
					</a>
				</article>
			))}
		</div>
		<div class="mt-20 text-center reveal-on-scroll">
			<a class="inline-block bg-primary text-white px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform shadow-lg shadow-primary/20" href="#contact">
				Porozmawiajmy o Twoim projekcie
			</a>
		</div>
	</div>
</section>
