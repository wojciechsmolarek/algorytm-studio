---
interface Props {
	title: string;
	subtitle: string;
	primaryCta: { text: string; href: string };
	secondaryCta: { text: string; href: string };
	image: { src: string; alt: string };
}

const { title, subtitle, primaryCta, secondaryCta, image } = Astro.props;
---

<header class="relative min-h-[80vh] flex flex-col justify-center pt-32 pb-20 px-6 md:px-12 lg:px-24 bg-muted">
	<div class="max-w-6xl mx-auto w-full">
		<div class="reveal-on-scroll max-w-3xl">
			<h1
				class="font-serif text-4xl md:text-6xl lg:text-7xl leading-[1.15] mb-6 text-balance"
				set:html={title}
			/>
			<p class="text-lg md:text-xl text-muted-foreground mb-10 leading-relaxed max-w-2xl" set:html={subtitle} />
			<div class="flex flex-wrap gap-4">
				<a
					class="bg-primary text-white px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform shadow-lg shadow-primary/20"
					href={primaryCta.href}
				>
					{primaryCta.text}
				</a>
				<a
					class="bg-white text-foreground border border-border px-8 py-4 rounded-full font-medium hover:bg-muted transition"
					href={secondaryCta.href}
				>
					{secondaryCta.text}
				</a>
			</div>
		</div>
	</div>
</header>
