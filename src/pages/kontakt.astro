---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experts } from "../config/experts";
import { siteConfig } from "../config/site";

const metadata = {
    title: "Kontakt",
    description: "Skontaktuj się z nami, aby omówić Twój projekt B2B.",
};
---

<BaseLayout {metadata}>
    <section class="pt-40 pb-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                <div class="reveal-on-scroll">
                    <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Kontakt</span>
                    <h1 class="font-serif text-5xl md:text-7xl leading-tight mb-8 text-balance">
                        <span class="inline-block" aria-hidden="true">&rarr;</span> Porozmawiajmy
                    </h1>
                    <p class="text-muted-foreground text-lg max-w-md leading-relaxed mb-8">
                        Masz projekt? Potrzebujesz konsultacji? A może po prostu chcesz zapytać o możliwości współpracy? Napisz do nas.
                    </p>

                    <div class="mt-16 space-y-12">
                        <div>
                            <h3 class="uppercase tracking-widest text-xs font-medium mb-4">Adres</h3>
                            <p class="text-muted-foreground">Bydgoszcz, ul. Sępia 4</p>
                        </div>
                        <div>
                            <h3 class="uppercase tracking-widest text-xs font-medium mb-4">Telefon</h3>
                            <p class="text-muted-foreground">{siteConfig.tel}</p>
                        </div>
                        <div>
                            <h3 class="uppercase tracking-widest text-xs font-medium mb-4">Kontakt e-mail</h3>
                            <div class="space-y-2">
                                <a class="block text-muted-foreground hover:text-foreground transition-colors" href="mailto:kontakt@algorytm.studio">kontakt@algorytm.studio</a>
                                {experts.map((expert) => (
                                    <a class="block text-muted-foreground hover:text-foreground transition-colors" href={`mailto:${expert.email}`}>
                                        {expert.email} — {expert.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-card border border-border p-8 md:p-12 rounded-lg reveal-on-scroll">
                    <iframe
                        src="https://maps.google.com/maps?q=S%C4%99pia%204%2C%20Bydgoszcz&t=&z=15&ie=UTF8&iwloc=&output=embed"
                        width="100%"
                        height="100%"
                        style="border:0; min-height: 400px;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                    ></iframe>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
