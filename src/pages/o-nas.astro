---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experts } from "../config/experts";

const metadata = {
    title: "O nas",
    description: "Poznaj zespół B2B Collective - kolektyw ekspertów SEO, Web Development i Strategii.",
};
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="pt-36 pb-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto reveal-on-scroll">
            <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">O nas</span>
            <h1 class="font-serif text-4xl md:text-6xl leading-tight mb-6 text-balance max-w-3xl">
                Kolektyw trzech ekspertów,<br/>
                <span class="text-primary">nie agencja.</span>
            </h1>
            <p class="text-lg max-w-2xl text-muted-foreground leading-relaxed">
                Nie zatrudniamy handlowców ani project managerów. Od pierwszego maila do wdrożenia rozmawiasz z osobami, które realnie pracują nad Twoim projektem.
            </p>
        </div>
    </section>

    <!-- Team -->
    <section class="py-20 px-6 md:px-12 lg:px-24">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-14 reveal-on-scroll">
                <h2 class="font-serif text-3xl md:text-4xl mb-4">Poznaj nas</h2>
                <p class="text-muted-foreground max-w-xl mx-auto leading-relaxed">
                    Trzech specjalistów, którzy łączą kompetencje potrzebne do skutecznej obecności w sieci.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {experts.map((expert) => (
                    <div class="group bg-card rounded-3xl p-6 border border-border text-center reveal-on-scroll hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                        <div class="relative w-24 h-24 mx-auto mb-4 overflow-hidden rounded-full border-4 border-muted">
                            <img
                                alt={expert.name}
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                src={expert.image}
                                loading="lazy"
                            />
                        </div>
                        <h3 class="text-xl font-serif mb-1">{expert.name}</h3>
                        <p class="text-xs font-bold uppercase tracking-wide text-primary mb-3">{expert.role}</p>
                        <p class="text-sm text-muted-foreground leading-relaxed">{expert.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Values -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-14 reveal-on-scroll">
                <h2 class="font-serif text-3xl md:text-4xl mb-4">Dlaczego kolektyw?</h2>
                <p class="text-muted-foreground max-w-2xl mx-auto leading-relaxed">
                    Współpraca z nami wygląda inaczej niż w typowej agencji. Bez zbędnych struktur, szybciej i bliżej biznesu.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="reveal-on-scroll bg-card rounded-3xl p-8 border border-border">
                    <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-5">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
                    </div>
                    <p class="mb-3 font-medium text-foreground text-xl">Ekspertyza</p>
                    <p class="text-muted-foreground leading-relaxed">Każdy z nas jest specjalistą w swojej dziedzinie z wieloletnim doświadczeniem w B2B.</p>
                </div>
                <div class="reveal-on-scroll bg-card rounded-3xl p-8 border border-border">
                    <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-5">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                    </div>
                    <p class="mb-3 font-medium text-foreground text-xl">Transparentność</p>
                    <p class="text-muted-foreground leading-relaxed">Widzisz cały proces, znasz każdego członka zespołu. Nie ukrywamy się za strukturami korporacyjnymi.</p>
                </div>
                <div class="reveal-on-scroll bg-card rounded-3xl p-8 border border-border">
                    <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-5">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    </div>
                    <p class="mb-3 font-medium text-foreground text-xl">Efektywność</p>
                    <p class="text-muted-foreground leading-relaxed">Bez zbędnych warstw decyzyjnych. Szybsze wdrożenia, lepsza komunikacja, realne rezultaty.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
