		description="Eliminujemy szum komunikacyjny. Rozmawiasz bezpośrednio z osobami, które wykonują pracę. To gwarantuje jakość i szybkość wdrażania zmian."
	/>

	<ServicesSection services={services} />

	<StrategySection
		headline="Strategiczne podejście do B2B"
		columns={strategyColumns}
	/>

	<ClientsSection clients={clients} />

	<KnowledgeSection articles={articles} />
