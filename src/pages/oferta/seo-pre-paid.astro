---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metadata = {
    title: "SEO w modelu pre-paid",
    description: "Elastyczny model współpracy SEO w systemie pre-paid. Kupujesz pakiet godzin, my realizujemy zadania według Twoich priorytetów.",
};

const advantages = [
    {
        title: "Pełna kontrola budżetu",
        description: "Wiesz dokładnie, ile wydajesz. Kupujesz pakiet godzin z góry i decydujesz, na co je przeznaczyć. Bez ukrytych kosztów.",
    },
    {
        title: "Brak długoterminowych umów",
        description: "Nie wiążesz się umową na 12 miesięcy. Kupujesz tyle godzin, ile aktualnie potrzebujesz. Skalujesz w górę lub w dół.",
    },
    {
        title: "Transparentne rozliczenie",
        description: "Każda godzina jest udokumentowana. Wiesz dokładnie, jakie zadania zostały zrealizowane i ile czasu zajęły.",
    },
    {
        title: "Elastyczność działań",
        description: "Dziś potrzebujesz audytu, jutro optymalizacji treści, za tydzień analizy konkurencji. Ty decydujesz o priorytetach.",
    },
];

const howItDiffers = [
    {
        title: "Tradycyjny model agencyjny",
        items: [
            "Umowa na 12+ miesięcy",
            "Stały abonament niezależnie od pracy",
            "Narzucony zakres działań",
            "Rozliczenie za efekt (często nieokreślony)",
            "Brak wglądu w realne godziny pracy",
        ],
        isHighlighted: false,
    },
    {
        title: "Nasz model pre-paid",
        items: [
            "Bez umów długoterminowych",
            "Płacisz za realne godziny pracy",
            "Ty decydujesz o priorytetach",
            "Rozliczenie za czas i konkretne zadania",
            "Pełna transparentność i raporty",
        ],
        isHighlighted: true,
    },
];

const processSteps = [
    {
        num: "01",
        title: "Wybierz pakiet",
        description: "Dobierz liczbę godzin do skali Twojego projektu. Pakiety od 10 do 80 godzin miesięcznie z degresywną stawką.",
    },
    {
        num: "02",
        title: "Ustal priorytety",
        description: "Wspólnie tworzymy listę zadań i ustalamy ich kolejność. Ty decydujesz, co jest najważniejsze dla Twojego biznesu.",
    },
    {
        num: "03",
        title: "Realizacja i raport",
        description: "Realizujemy zadania według ustalonych priorytetów. Po każdym okresie rozliczeniowym dostajesz raport z wykonanych prac.",
    },
];
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="pt-36 pb-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Oferta</span>
                <h1 class="font-serif text-4xl md:text-6xl leading-tight mb-6 text-balance max-w-3xl">
                    SEO w modelu <span class="text-primary">"pre-paid"</span>
                </h1>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-px bg-foreground shrink-0"></div>
                    <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                        Kupujesz godziny pracy eksperta, nie abonament. Pełna transparentność, elastyczność i kontrola nad budżetem SEO.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Comparison -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="mb-14 reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Pre-paid vs abonament</span>
                <h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">
                    Dlaczego <span class="text-primary">pre-paid?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {howItDiffers.map((model) => (
                    <div class={`rounded-3xl p-8 md:p-10 reveal-on-scroll hover:shadow-lg transition-all duration-300 ${model.isHighlighted ? 'bg-primary text-white' : 'bg-card border border-border'}`}>
                        <h3 class={`text-xl font-medium mb-6 ${model.isHighlighted ? 'text-white' : 'text-foreground'}`}>{model.title}</h3>
                        <ul class="flex flex-col gap-3">
                            {model.items.map((item) => (
                                <li class={`flex items-start gap-3 text-sm ${model.isHighlighted ? 'text-white/80' : 'text-muted-foreground'}`}>
                                    <span class={`mt-1.5 w-1.5 h-1.5 rounded-full shrink-0 ${model.isHighlighted ? 'bg-white' : 'bg-accent'}`}></span>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Advantages -->
    <section class="py-20 px-6 md:px-12 lg:px-24">
        <div class="max-w-6xl mx-auto">
            <div class="mb-14 reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Korzyści</span>
                <h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">
                    Co zyskujesz <span class="text-primary">w modelu pre-paid?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {advantages.map((item) => (
                    <div class="bg-card rounded-3xl p-8 border border-border reveal-on-scroll hover:shadow-lg transition-all duration-300">
                        <h3 class="text-xl font-medium mb-3">{item.title}</h3>
                        <p class="text-muted-foreground leading-relaxed">{item.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="mb-14 reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Proces</span>
                <h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">Jak <span class="text-primary">zaczynamy?</span></h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {processSteps.map((step) => (
                    <div class="bg-card rounded-3xl p-8 border border-border reveal-on-scroll hover:shadow-lg transition-all duration-300">
                        <span class="block text-4xl font-serif text-muted-foreground/40 mb-6">{step.num}</span>
                        <h3 class="text-xl font-medium mb-4">{step.title}</h3>
                        <p class="text-muted-foreground leading-relaxed text-sm">{step.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="bg-primary rounded-3xl p-8 md:p-12 lg:p-16 text-white text-center reveal-on-scroll">
                <h2 class="font-serif text-3xl md:text-5xl mb-6 text-balance max-w-3xl mx-auto">
                    Zacznij od pierwszego pakietu.
                </h2>
                <p class="text-white/80 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
                    Nie musisz decydować się na wszystko od razu. Zacznij od małego pakietu, przetestuj nasz model współpracy i skaluj dalej.
                </p>
                <a class="inline-block bg-white text-primary px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform shadow-lg" href="/kontakt">
                    Zapytaj o cennik
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
