---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metadata = {
    title: "Migracje stron i sklepów internetowych",
    description: "Bezpieczna migracja strony lub sklepu internetowego bez utraty widoczności w Google. Pełny nadzór nad procesem przenoszenia serwisu.",
};

const processSteps = [
    {
        num: "01",
        title: "Audyt przed-migracyjny",
        description: "Inwentaryzacja wszystkich URL-i, analiza profilu linków, mapowanie przekierowań 1:1, identyfikacja kluczowych podstron generujących ruch organiczny.",
    },
    {
        num: "02",
        title: "Plan migracji",
        description: "Szczegółowy plan działania z harmonogramem, checklistami i scenariuszami awaryjnymi. Każdy etap jest udokumentowany i zatwierdzony.",
    },
    {
        num: "03",
        title: "Wdrożenie i monitoring",
        description: "Nadzór nad wdrożeniem, testy przekierowań, walidacja danych strukturalnych. Po migracji - monitoring widoczności i szybka reakcja na problemy.",
    },
];

const risks = [
    {
        title: "Utrata ruchu organicznego",
        description: "Bez prawidłowych przekierowań 301 tracisz cały autorytet zgromadzony przez lata. Jedna pomyłka może kosztować miesiące odbudowy.",
    },
    {
        title: "Zepsute linkowanie wewnętrzne",
        description: "Nowa struktura URL bez mapy przekierowań prowadzi do błędów 404, frustracji użytkowników i spadku pozycji w wynikach wyszukiwania.",
    },
    {
        title: "Utrata danych strukturalnych",
        description: "Schema.org, Open Graph, meta tagi - ich brak po migracji oznacza gorsze wyświetlanie w wynikach i spadek CTR.",
    },
    {
        title: "Problemy z indeksowaniem",
        description: "Błędna konfiguracja robots.txt lub sitemap.xml na nowej stronie może zablokować Google przed indeksowaniem Twoich treści.",
    },
];

const types = [
    {
        title: "Zmiana domeny",
        description: "Przeniesienie serwisu na nową domenę z zachowaniem całego autorytetu i pozycji w wynikach wyszukiwania.",
    },
    {
        title: "Zmiana CMS / platformy",
        description: "Migracja z WordPressa, Shopify, Magento lub innych platform na nowe rozwiązanie technologiczne.",
    },
    {
        title: "Zmiana struktury URL",
        description: "Reorganizacja architektury informacji i struktury linków bez utraty dotychczasowej widoczności.",
    },
    {
        title: "Łączenie domen",
        description: "Konsolidacja wielu serwisów pod jedną domeną z prawidłowym transferem autorytetu i ruchu.",
    },
    {
        title: "Migracja HTTP na HTTPS",
        description: "Bezpieczne przejście na protokół HTTPS z pełnym zachowaniem pozycji i uniknięciem mixed content.",
    },
    {
        title: "Redesign strony",
        description: "Nadzór SEO nad procesem redesignu, by nowy wygląd nie oznaczał nowych problemów z widocznością.",
    },
];
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="pt-36 pb-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Oferta</span>
                <h1 class="font-serif text-4xl md:text-6xl leading-tight mb-6 text-balance max-w-3xl">
                    Migracje stron <span class="text-primary">i sklepów</span>
                </h1>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-px bg-foreground shrink-0"></div>
                    <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                        Źle przeprowadzona migracja to najczęstszy powód katastrofalnych spadków widoczności. Nadzorujemy cały proces, by Twoja strona nie straciła ani jednej pozycji.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Risks Section -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="mb-14 reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Ryzyka</span>
                <h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">
                    Dlaczego migracje <span class="text-primary">są ryzykowne?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {risks.map((risk) => (
                    <div class="bg-card rounded-3xl p-8 border border-border reveal-on-scroll hover:shadow-lg transition-all duration-300">
                        <h3 class="text-xl font-medium mb-3">{risk.title}</h3>
                        <p class="text-muted-foreground leading-relaxed">{risk.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="py-20 px-6 md:px-12 lg:px-24">
        <div class="max-w-6xl mx-auto">
            <div class="mb-14 reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Proces</span>
                <h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">Nasz <span class="text-primary">proces</span></h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {processSteps.map((step) => (
                    <div class="bg-card rounded-3xl p-8 border border-border reveal-on-scroll hover:shadow-lg transition-all duration-300">
                        <span class="block text-4xl font-serif text-muted-foreground/40 mb-6">{step.num}</span>
                        <h3 class="text-xl font-medium mb-4">{step.title}</h3>
                        <p class="text-muted-foreground leading-relaxed text-sm">{step.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Migration Types -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="mb-14 reveal-on-scroll">
                <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-sm uppercase tracking-widest font-medium mb-6">Rodzaje</span>
                <h2 class="font-serif text-3xl md:text-4xl mb-4 text-balance max-w-3xl">
                    Jakie migracje <span class="text-primary">realizujemy?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {types.map((type) => (
                    <article class="bg-card rounded-3xl p-8 border border-border reveal-on-scroll hover:shadow-lg transition-all duration-300">
                        <h3 class="text-xl font-medium mb-3">{type.title}</h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">{type.description}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto">
            <div class="bg-primary rounded-3xl p-8 md:p-12 lg:p-16 text-white text-center reveal-on-scroll">
                <h2 class="font-serif text-3xl md:text-5xl mb-6 text-balance max-w-3xl mx-auto">
                    Planujesz migrację?
                </h2>
                <p class="text-white/80 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
                    Porozmawiajmy zanim zaczniesz. Prawidłowe przygotowanie to klucz do bezpiecznej migracji bez strat w widoczności.
                </p>
                <a class="inline-block bg-white text-primary px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform shadow-lg" href="/kontakt">
                    Skonsultuj migrację
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
