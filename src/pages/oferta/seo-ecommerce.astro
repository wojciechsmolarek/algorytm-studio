---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metadata = {
    title: "SEO dla e-commerce",
    description: "Pozycjonowanie sklepów internetowych, które przekładają się na realną sprzedaż. Strategia SEO dostosowana do specyfiki e-commerce B2B.",
};

const challenges = [
    {
        title: "Tysiące produktów, unikalne opisy",
        description: "Skalowalna strategia treści produktowych, która eliminuje duplikaty i buduje unikalną wartość każdej podstrony.",
    },
    {
        title: "Filtracja i nawigacja fasetowa",
        description: "Prawidłowe zarządzanie parametrami filtrowania, by unikać duplikatów URL i nieefektywnego wykorzystania crawl budget.",
    },
    {
        title: "Sezonowość i rotacja asortymentu",
        description: "Strategia obsługi produktów wycofanych, sezonowych i chwilowo niedostępnych bez utraty zgromadzonego autorytetu.",
    },
    {
        title: "Struktura kategorii",
        description: "Optymalizacja drzewa kategorii pod kątem intencji wyszukiwania. Budowanie silnych stron kategorii, które rankują na frazy ogólne.",
    },
];

const scope = [
    {
        num: "01",
        title: "Audyt e-commerce SEO",
        description: "Kompleksowa analiza sklepu: architektura, indeksowalność, wydajność, treści produktowe, dane strukturalne i linkowanie wewnętrzne.",
    },
    {
        num: "02",
        title: "Strategia słów kluczowych",
        description: "Mapowanie fraz na kategorie, produkty i treści blogowe. Identyfikacja fraz z intencją zakupową o najwyższym potencjale konwersji.",
    },
    {
        num: "03",
        title: "Optymalizacja treści",
        description: "Szablony opisów produktów i kategorii, meta tagi, opisy filtrowane, FAQ produktowe i treści wspierające SEO.",
    },
    {
        num: "04",
        title: "Technical SEO",
        description: "Optymalizacja paginacji, kanonikalizacji, Schema.org dla produktów (Product, Offer, AggregateRating), feed produktowy.",
    },
    {
        num: "05",
        title: "Link building",
        description: "Budowanie autorytetu sklepu poprzez linkowanie z branżowych źródeł, recenzje, porównywania i treści eksperckie.",
    },
    {
        num: "06",
        title: "Analityka i raportowanie",
        description: "Konfiguracja śledzenia e-commerce w GA4, atrybucja SEO do przychodów, raporty miesięczne z KPI biznesowymi.",
    },
];

const platforms = [
    "Shopify",
    "WooCommerce",
    "Magento / Adobe Commerce",
    "PrestaShop",
    "Shoper",
    "IdoSell",
    "BaseLinker + headless",
    "Custom e-commerce",
];
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 px-6 md:px-12 lg:px-24 border-b border-border">
        <div class="max-w-5xl mx-auto">
            <div class="reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Oferta</span>
                <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-8 text-balance">
                    SEO dla <span class="italic text-muted-foreground">e-commerce</span>
                </h1>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-px bg-foreground shrink-0"></div>
                    <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                        Sklep internetowy to nie blog - wymaga specjalistycznego podejścia do SEO. Optymalizujemy każdy element, od kart produktów po nawigację fasetową.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Challenges -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Wyzwania</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Specyfika SEO <span class="italic text-muted-foreground">w e-commerce</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
                {challenges.map((item) => (
                    <div class="border-t border-border pt-6 reveal-on-scroll">
                        <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                        <p class="text-muted-foreground leading-relaxed">{item.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Scope -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="mb-20 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Zakres</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Co robimy <span class="italic text-muted-foreground">dla Twojego sklepu?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
                {scope.map((item) => (
                    <article class="group border-t border-border pt-6 reveal-on-scroll">
                        <span class="block text-4xl font-serif text-border mb-4 group-hover:text-foreground transition-colors duration-500">{item.num}</span>
                        <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">{item.description}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- Platforms -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-card">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Platformy</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Pracujemy z <span class="italic text-muted-foreground">każdą platformą</span>
                </h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 reveal-on-scroll">
                {platforms.map((platform) => (
                    <div class="border border-border px-5 py-4 text-sm text-muted-foreground hover:text-foreground hover:border-foreground transition-colors">
                        {platform}
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-5xl mx-auto text-center reveal-on-scroll">
            <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl mb-8 text-balance">
                Twój sklep zasługuje na więcej ruchu.
            </h2>
            <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-12 leading-relaxed">
                Bezpłatna analiza potencjału SEO Twojego sklepu internetowego. Pokaż nam swój asortyment, a powiemy Ci, jak zwiększać sprzedaż organicznie.
            </p>
            <a class="inline-block bg-foreground text-background px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform" href="/#contact">
                Zamów bezpłatną analizę
            </a>
        </div>
    </section>
</BaseLayout>
