---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metadata = {
    title: "Strony, które zarabiają",
    description: "Projektujemy serwisy nastawione na konwersje. UX/UI dopasowany do ścieżki zakupowej klienta B2B, maksymalizujący zapytania ofertowe.",
};

const principles = [
    {
        title: "Konwersja przede wszystkim",
        description: "Każdy element strony służy jednemu celowi - przekształceniu odwiedzającego w lead. Projektujemy ścieżki użytkownika, które naturalnie prowadzą do zapytania ofertowego.",
    },
    {
        title: "Szybkość ładowania",
        description: "Strona ładująca się w 1 sekundę konwertuje 3x lepiej niż strona ładująca się w 5 sekund. Optymalizujemy każdy kilobajt.",
    },
    {
        title: "Mobile-first, nie mobile-friendly",
        description: "Ponad 60% ruchu B2B pochodzi z urządzeń mobilnych. Projektujemy od mobile w górę, nie odwrotnie.",
    },
    {
        title: "SEO w DNA",
        description: "Każda strona jest od początku projektowana z myślą o widoczności w Google. Struktura, treści, szybkość - SEO nie jest dodatkiem, to fundament.",
    },
];

const processSteps = [
    {
        num: "01",
        title: "Discovery i strategia",
        description: "Analiza Twojego biznesu, konkurencji i grupy docelowej. Definiujemy cele, KPI i ścieżkę użytkownika, zanim narysujemy pierwszy piksel.",
    },
    {
        num: "02",
        title: "UX Research i prototyp",
        description: "Wireframe'y i prototypy klikalne, testowane z realnymi użytkownikami. Walidujemy każde założenie, zanim przejdziemy do designu.",
    },
    {
        num: "03",
        title: "Design i development",
        description: "Nowoczesny design nastawiony na konwersje. Development w technologiach zapewniających wydajność: Astro, Next.js, headless CMS.",
    },
    {
        num: "04",
        title: "Testy i optymalizacja",
        description: "Testy A/B, analityka, heatmapy. Po wdrożeniu ciągle optymalizujemy stronę, by zwiększać wskaźniki konwersji.",
    },
];

const technologies = [
    "Astro",
    "Next.js",
    "React",
    "Headless CMS",
    "Tailwind CSS",
    "Vercel",
    "Cloudflare",
    "Analytics & Tracking",
];

const deliverables = [
    {
        title: "Strona korporacyjna B2B",
        description: "Profesjonalny serwis firmowy, który buduje zaufanie, prezentuje ofertę i generuje leady. Od wizytówki po rozbudowany portal.",
    },
    {
        title: "Landing page",
        description: "Dedykowane strony docelowe pod kampanie, produkty lub usługi. Zoptymalizowane pod jeden cel konwersji.",
    },
    {
        title: "Mikrostrony produktowe",
        description: "Samodzielne serwisy prezentujące produkt lub usługę. Idealne do kampanii i pozycjonowania na konkretne frazy.",
    },
    {
        title: "Redesign istniejącego serwisu",
        description: "Odświeżenie designu i optymalizacja UX przy zachowaniu widoczności SEO. Nadzór nad migracją włączony w cenę.",
    },
];
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 px-6 md:px-12 lg:px-24 border-b border-border">
        <div class="max-w-5xl mx-auto">
            <div class="reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Oferta</span>
                <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-8 text-balance">
                    Strony, które <span class="italic text-muted-foreground">zarabiają</span>
                </h1>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-px bg-foreground shrink-0"></div>
                    <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                        Nie budujemy stron "bo trzeba mieć stronę". Projektujemy serwisy, które są przedłużeniem Twojego działu sprzedaży - generują leady, budują zaufanie i zamykają deale.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Principles -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Filozofia</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Nasze <span class="italic text-muted-foreground">zasady projektowania</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
                {principles.map((item) => (
                    <div class="border-t border-border pt-6 reveal-on-scroll">
                        <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                        <p class="text-muted-foreground leading-relaxed">{item.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <h2 class="font-serif text-4xl md:text-6xl mb-16 reveal-on-scroll text-balance">Jak pracujemy?</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
                {processSteps.map((step) => (
                    <div class="reveal-on-scroll">
                        <span class="block text-6xl font-serif text-border mb-6">{step.num}</span>
                        <h3 class="text-xl font-bold mb-4">{step.title}</h3>
                        <p class="text-muted-foreground leading-relaxed text-sm">{step.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Deliverables -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-card">
        <div class="max-w-7xl mx-auto">
            <div class="mb-20 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Co tworzymy</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Rodzaje <span class="italic text-muted-foreground">projektów</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
                {deliverables.map((item) => (
                    <div class="border-t border-border pt-6 reveal-on-scroll">
                        <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                        <p class="text-muted-foreground leading-relaxed">{item.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Technologies -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Technologie</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Narzędzia, które <span class="italic text-muted-foreground">wybieramy</span>
                </h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 reveal-on-scroll">
                {technologies.map((tech) => (
                    <div class="border border-border px-5 py-4 text-sm text-muted-foreground hover:text-foreground hover:border-foreground transition-colors">
                        {tech}
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-card">
        <div class="max-w-5xl mx-auto text-center reveal-on-scroll">
            <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl mb-8 text-balance">
                Twoja strona może sprzedawać więcej.
            </h2>
            <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-12 leading-relaxed">
                Porozmawiajmy o tym, jak Twoja strona może lepiej wspierać sprzedaż. Bezpłatna analiza obecnego serwisu i rekomendacje zmian.
            </p>
            <a class="inline-block bg-foreground text-background px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform" href="/#contact">
                Zamów bezpłatną analizę
            </a>
        </div>
    </section>
</BaseLayout>
