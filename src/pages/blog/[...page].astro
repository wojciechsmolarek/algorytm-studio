---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "../../components/ui/Headline.astro";
import Pagination from "../../components/ui/Pagination.astro";
import PostItem from "../../components/blog/PostItem.astro";
import { getAllCategories } from "../../lib/wordpress";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const blogEntries = await getCollection("blog");
    const sortedPosts = blogEntries
        .filter((post) => post.data && post.data.pubDate)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return paginate(sortedPosts, { pageSize: 9 });
}

const { page } = Astro.props;
const blog = page.data;
const categories = await getAllCategories();

const metadata = {
    title: page.currentPage === 1 ? "Blog — Studio Algorytm" : `Blog — Strona ${page.currentPage} | Studio Algorytm`,
    description: "Artykuły ekspertów Studio Algorytm — SEO, web development, strategia B2B.",
};
---

<BaseLayout metadata={metadata}>
    <section class="pt-36 pb-8 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-6xl mx-auto text-center">
            <Headline
                tagline="Blog"
                title={page.currentPage === 1 ? "Baza Wiedzy" : `Baza Wiedzy — Strona ${page.currentPage}`}
                subtitle="Artykuły ekspertów Studio Algorytm — SEO, web development, strategia B2B."
                classes={{
                    container: "mb-12",
                    title: "font-serif mb-4 text-4xl font-bold tracking-tight text-foreground md:text-6xl",
                    subtitle: "mx-auto max-w-3xl text-xl text-muted-foreground",
                }}
            />
        </div>
    </section>

    <section class="mb-8 px-6 md:px-12 lg:px-24">
        <div class="max-w-6xl mx-auto">
            {categories.length > 0 && (
                <nav class="flex flex-wrap gap-2 justify-center" aria-label="Kategorie bloga">
                    <a
                        href="/blog"
                        class="px-4 py-2 bg-primary text-white font-semibold text-sm rounded-full transition-colors"
                    >
                        Wszystkie
                    </a>
                    {categories.map((category) => (
                        <a
                            href={`/blog/kategoria/${category.slug}`}
                            class="px-4 py-2 bg-card text-muted-foreground border border-border hover:border-primary hover:text-foreground font-medium text-sm rounded-full transition-colors"
                        >
                            {category.name} ({category.count})
                        </a>
                    ))}
                </nav>
            )}
        </div>
    </section>

    <section class="py-12 px-6 md:px-12 lg:px-24">
        <div class="max-w-6xl mx-auto">
            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                {blog.map((post) => <PostItem post={post} />)}
            </div>
            <Pagination page={page} />
        </div>
    </section>
</BaseLayout>
