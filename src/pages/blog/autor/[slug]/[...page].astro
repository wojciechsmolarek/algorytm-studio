---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostItem from '../../../../components/blog/PostItem.astro';
import Pagination from '../../../../components/ui/Pagination.astro';
import { getAllAuthors, getPostsByAuthor, type BlogPost, type Author } from '../../../../lib/wordpress';

export const getStaticPaths = (async ({ paginate }) => {
  const authors = await getAllAuthors();

  const paths = await Promise.all(
    authors.map(async (author) => {
      const authorPosts = await getPostsByAuthor(author.slug);
      if (authorPosts.length === 0) return [];
      return paginate(authorPosts, {
        pageSize: 9,
        params: { slug: author.slug },
        props: { author, postsCount: authorPosts.length },
      });
    })
  );

  return paths.flat();
}) satisfies GetStaticPaths;

const { page, author, postsCount } = Astro.props as {
  page: any;
  author: Author;
  postsCount: number;
};

const gridPosts = page.data as BlogPost[];

const metadata = {
  title: page.currentPage === 1
    ? `${author.name} — Autor | Studio Algorytm`
    : `${author.name} — Strona ${page.currentPage} | Studio Algorytm`,
  description: author.description || `Artykuły autora ${author.name}.`,
};
---

<BaseLayout {metadata}>
  <section class="pt-36 pb-12 px-6 md:px-12 lg:px-24 bg-muted">
    <div class="max-w-6xl mx-auto">
      <div class="bg-card rounded-3xl border border-border overflow-hidden">
        <div class="grid lg:grid-cols-[300px,1fr] gap-0">
          <div class="bg-primary p-8 flex items-center justify-center">
            {author.photo ? (
              <img
                src={author.photo}
                alt={author.name}
                width={300}
                height={400}
                loading="eager"
                class="w-full h-auto rounded-2xl shadow-2xl"
              />
            ) : (
              <div class="w-48 h-48 rounded-full overflow-hidden border-4 border-white shadow-2xl">
                <img
                  src={author.avatar}
                  alt={author.name}
                  width={192}
                  height={192}
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
            )}
          </div>

          <div class="p-8 lg:p-12 flex flex-col justify-center">
            {author.role && (
              <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest rounded-full mb-4 w-fit">
                {author.role}
              </span>
            )}

            <h1 class="font-serif text-4xl lg:text-5xl font-bold text-foreground mb-4">
              {page.currentPage === 1 ? author.name : `${author.name} — Strona ${page.currentPage}`}
            </h1>

            {author.expertise && (
              <p class="text-base text-muted-foreground leading-relaxed mb-6">
                {author.expertise}
              </p>
            )}

            {author.description && (
              <p class="text-sm text-muted-foreground leading-relaxed mb-6">
                {author.description}
              </p>
            )}

            {author.quote && (
              <blockquote class="border-l-4 border-primary pl-6 py-2 mb-6 italic text-muted-foreground">
                "{author.quote}"
              </blockquote>
            )}

            <div class="flex items-center gap-2 text-sm text-muted-foreground mt-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>
                {postsCount} {postsCount === 1 ? 'artykuł' : postsCount < 5 ? 'artykuły' : 'artykułów'}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 px-6 md:px-12 lg:px-24">
    <div class="max-w-6xl mx-auto">
      {gridPosts.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {gridPosts.map((post) => {
            return <PostItem post={post} />;
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-muted-foreground text-lg">Ten autor nie opublikował jeszcze żadnych artykułów.</p>
        </div>
      )}

      <Pagination page={page} />

      <div class="mt-12 text-center">
        <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-foreground font-medium transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Powrót do bloga
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
