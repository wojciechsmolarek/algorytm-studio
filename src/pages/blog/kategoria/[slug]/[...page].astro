---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostItem from '../../../../components/blog/PostItem.astro';
import Pagination from '../../../../components/ui/Pagination.astro';
import { getAllCategories, getPostsByCategory, type BlogPost, type Category } from '../../../../lib/wordpress';

export const getStaticPaths = (async ({ paginate }) => {
  const categories = await getAllCategories();

  const paths = await Promise.all(
    categories.map(async (category) => {
      const categoryPosts = await getPostsByCategory(category.slug);
      if (categoryPosts.length === 0) return [];
      return paginate(categoryPosts, {
        pageSize: 9,
        params: { slug: category.slug },
        props: { category },
      });
    })
  );

  return paths.flat();
}) satisfies GetStaticPaths;

const { page, category } = Astro.props as {
  page: any;
  category: Category;
};

const gridPosts = page.data as BlogPost[];
const allCategories = await getAllCategories();

const metadata = {
  title: page.currentPage === 1
    ? `${category.name} — Blog | Studio Algorytm`
    : `${category.name} — Strona ${page.currentPage} | Studio Algorytm`,
  description: `Artykuły z kategorii ${category.name}.`,
};
---

<BaseLayout {metadata}>
  <section class="pt-36 pb-8 px-6 md:px-12 lg:px-24 bg-muted">
    <div class="max-w-6xl mx-auto text-center">
      <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest rounded-full mb-4">
        Kategoria
      </span>
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-foreground mb-4">
        {page.currentPage === 1 ? category.name : `${category.name} — Strona ${page.currentPage}`}
      </h1>
      <p class="text-muted-foreground text-lg">
        {category.count} {category.count === 1 ? 'artykuł' : category.count < 5 ? 'artykuły' : 'artykułów'}
      </p>
    </div>
  </section>

  <section class="mb-8 px-6 md:px-12 lg:px-24">
    <div class="max-w-6xl mx-auto">
      <nav class="flex flex-wrap gap-2 justify-center" aria-label="Filtruj po kategorii">
        <a
          href="/blog"
          class="px-4 py-2 bg-card text-muted-foreground border border-border hover:border-primary hover:text-foreground font-medium text-sm rounded-full transition-colors"
        >
          Wszystkie
        </a>
        {allCategories.map((cat) => (
          <a
            href={`/blog/kategoria/${cat.slug}`}
            class={`px-4 py-2 font-medium text-sm rounded-full transition-colors ${
              cat.slug === category.slug
                ? 'bg-primary text-white'
                : 'bg-card text-muted-foreground border border-border hover:border-primary hover:text-foreground'
            }`}
          >
            {cat.name}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <section class="py-12 px-6 md:px-12 lg:px-24">
    <div class="max-w-6xl mx-auto">
      {gridPosts.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {gridPosts.map((post) => {
            return <PostItem post={post} />;
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-muted-foreground text-lg">Brak artykułów w tej kategorii.</p>
        </div>
      )}

      <Pagination page={page} />

      <div class="mt-12 text-center">
        <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-foreground font-medium transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Powrót do bloga
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
